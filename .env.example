# =============================================================
# Socrates-Cube 环境变量模板
# 使用前：cp .env.example .env  然后填入真实值
# 警告：.env 文件已加入 .gitignore，禁止提交到版本控制！
# =============================================================

# 讯飞星火 API
XUNFEI_APP_ID=your_app_id_here
XUNFEI_API_KEY=your_api_key_here
XUNFEI_API_SECRET=your_api_secret_here
XUNFEI_SPARK_URL=wss://spark-api.xf-yun.com/v3.5/chat

# 讯飞 TTS（文字转语音）
XUNFEI_TTS_URL=wss://tts-api.xf-yun.com/v2/tts

# 数据库（默认 SQLite，生产可替换为 PostgreSQL）
DATABASE_URL=sqlite:///./edu_agent.db
# PostgreSQL 示例（可扩展）：
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/edu_agent

# 向量库路径
CHROMA_DB_PATH=./chroma_db

# 服务配置
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# CORS（开发阶段允许所有来源，生产阶段改为具体域名）
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]
