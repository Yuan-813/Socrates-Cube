# Python 虚拟环境
.venv/
venv/
env/

# 环境变量（含密钥，禁止上传）
.env

# Python 编译缓存
__pycache__/
*.py[cod]
*.pyo
*.pyd

# 数据目录（原始知识库文件不上传，避免版权问题）
data/

# 输出目录（生成内容、测试脚本等）
outputs/

# 向量数据库
chroma_db/

# SQLite 数据库文件
*.db
*.sqlite
*.sqlite3

# IDE
.vscode/
.idea/
*.swp
*.swo

# macOS
.DS_Store

# 测试覆盖率
.coverage
htmlcov/
.pytest_cache/

# 构建产物
dist/
build/
*.egg-info/

# Node（前端）
node_modules/
dist/
.env.local
